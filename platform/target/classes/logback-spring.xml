<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Include default spring boot logback configurations -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Properties for log directory and file naming -->
    <property name="LOG_FILE_DIR" value="${LOG_PATH:-./logs}"/>
    <property name="LOG_FILE_NAME" value="${LOG_FILE:-platform-service}"/>

    <!-- Local Console Appender (Clean, Colored, Readable) -->
    <appender name="LOCAL_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%-5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}</pattern>
        </encoder>
    </appender>

    <!-- Production Console Appender (Structured logs for indexing) -->
    <appender name="PROD_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- In a fully productionized system, this would output JSON (using logstash-logback-encoder) -->
            <!-- For Sprint 0, we output a highly structured, standard log format that is easy to index -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - [CorrelationID: %X{correlationId:-NONE}] [RequestID: %X{requestId:-NONE}] - %msg%n%wEx</pattern>
        </encoder>
    </appender>

    <!-- Rolling File Appender for Production Backup -->
    <appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE_DIR}/${LOG_FILE_NAME}.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - [CorrelationID: %X{correlationId:-NONE}] [RequestID: %X{requestId:-NONE}] - %msg%n%wEx</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- daily rollover -->
            <fileNamePattern>${LOG_FILE_DIR}/${LOG_FILE_NAME}-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <!-- or whenever the file size reaches 50MB -->
                <maxFileSize>50MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <!-- keep 30 days' worth of history capped at 3GB total size -->
            <maxHistory>30</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Local Profile Logging Configuration -->
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="LOCAL_CONSOLE"/>
        </root>
    </springProfile>

    <!-- Production Profile Logging Configuration -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="PROD_CONSOLE"/>
            <appender-ref ref="ROLLING_FILE"/>
        </root>
    </springProfile>

    <!-- Default Config (Fallback if no profile active) -->
    <springProfile name="!local &amp; !prod">
        <root level="INFO">
            <appender-ref ref="LOCAL_CONSOLE"/>
        </root>
    </springProfile>

</configuration>
